{
	"[astro]": {
		"editor.defaultFormatter": "astro-build.astro-vscode"
	},
	"biome.requireConfiguration": true,
	"chat.agent.maxRequests": 128,
	"chat.agent.thinkingStyle": "collapsedPreview",
	"chat.agentSkillsLocations": {
		".claude/skills": false,
		"~/.claude/skills": false
	},
	"chat.mcp.gallery.enabled": true,
	"chat.permissions.default": "autopilot",
	"chat.sessionSync.enabled": true,
	"chat.subagents.allowInvocationsFromSubagents": true,
	"diffEditor.experimental.showMoves": true,
	"diffEditor.hideUnchangedRegions.enabled": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"editor.accessibilitySupport": "off",
	"editor.aiStats.enabled": true,
	"editor.autoClosingComments": "never",
	"editor.autoClosingDelete": "always",
	"editor.autoClosingOvertype": "always",
	"editor.autoIndent": "advanced",
	"editor.codeActionsOnSave": [
		"source.organizeImports.ts",
		"source.format.oxc",
		"source.fixAll.ts",
		"source.fixAllDangerous.oxc"
	],
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.find.cursorMoveOnType": false,
	"editor.find.seedSearchStringFromSelection": "selection",
	"editor.fontFamily": "'FiraCode Nerd Font', Menlo, Monaco, 'Courier New', monospace",
	"editor.fontLigatures": true,
	"editor.guides.bracketPairs": "active",
	"editor.inlayHints.enabled": "offUnlessPressed",
	"editor.inlineSuggest.showToolbar": "always",
	"editor.linkedEditing": true,
	"editor.maxTokenizationLineLength": 1000,
	"editor.minimap.showSlider": "always",
	"editor.occurrencesHighlight": "multiFile",
	"editor.parameterHints.enabled": false,
	"editor.renderWhitespace": "all",
	"editor.snippetSuggestions": "bottom",
	"editor.suggest.insertMode": "replace",
	"editor.suggest.localityBonus": true,
	"editor.suggest.preview": true,
	"editor.tabSize": 2,
	"emmet.triggerExpansionOnTab": true,
	"explorer.confirmUndo": "verbose",
	"explorer.incrementalNaming": "smart",
	"files.associations": {
		".dev.vars{,.*}": "ini",
		".env{,.*}": "ini",
		"**/.husky/*": "shellscript"
	},
	"files.eol": "\n",
	"files.readonlyInclude": {
		"**/node_modules/**": true
	},
	"files.simpleDialog.enable": true,
	"git.autofetch": "all",
	"git.closeDiffOnOperation": true,
	"git.diagnosticsCommitHook.enabled": true,
	"git.fetchOnPull": true,
	"git.mergeEditor": true,
	"git.pruneOnFetch": true,
	"git.verboseCommit": true,
	"github.copilot.chat.commitMessageGeneration.instructions": [
		{
			"text": "Use English and Markdown formatting."
		},
		{
			"text": "In the subject line, use the imperative mood and omit articles where possible, such as a, an, and the."
		},
		{
			"text": "In the body, do not insert line breaks within paragraphs, to keep the text friendly for machine translation; assume there is no line length limit."
		},
		{
			"text": "Follow the Conventional Commits specification."
		},
		{
			"text": "Choose the commit type from the perspective of each project's primary stakeholders: end users for apps, consumers for packages or services."
		},
		{
			"text": "In a monorepo, include the names of affected projects in the commit scope, separated by commas and spaces. For changes involving dependencies, include `deps` as the first item. If the change is workspace-wide, omit all other scope items and keep `deps` only."
		}
	],
	"github.copilot.chat.languageContext.typescript.enabled": true,
	"github.copilot.chat.localeOverride": "ja",
	"github.copilot.chat.localIndex.enabled": true,
	"github.copilot.chat.searchSubagent.enabled": true,
	"github.copilot.chat.skillTool.enabled": true,
	"github.copilot.enable": {
		"markdown": true,
		"plaintext": true,
		"scminput": true
	},
	"js/ts.inlayHints.enumMemberValues.enabled": true,
	"js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
	"js/ts.inlayHints.parameterNames.enabled": "all",
	"js/ts.inlayHints.parameterTypes.enabled": true,
	"js/ts.inlayHints.propertyDeclarationTypes.enabled": true,
	"js/ts.inlayHints.variableTypes.enabled": true,
	"js/ts.preferences.autoImportSpecifierExcludeRegexes": ["^console$"],
	"js/ts.preferences.preferTypeOnlyAutoImports": true,
	"js/ts.tsdk.promptToUseWorkspaceVersion": true,
	"json.schemaDownload.trustedDomains": {
		"https://inlang.com/": true
	},
	"keyboard.dispatch": "keyCode",
	"oxc.fixKind": "all",
	"prettier.singleQuote": true,
	"prettier.useTabs": true,
	"redhat.telemetry.enabled": true,
	"scm.repositories.explorer": true,
	"scm.repositories.selectionMode": "single",
	"search.showLineNumbers": true,
	"terminal.explorerKind": "external",
	"terminal.external.osxExec": "Warp.app",
	"terminal.sourceControlRepositoriesKind": "external",
	"window.autoDetectColorScheme": true,
	"window.confirmBeforeClose": "keyboardOnly",
	"window.title": "${rootName}${separator}${activeFolderMedium}",
	"workbench.browser.dataStorage": "workspace",
	"workbench.browser.openLocalhostLinks": true,
	"workbench.commandPalette.experimental.enableNaturalLanguageSearch": false,
	"workbench.editor.alwaysShowEditorActions": true,
	"workbench.editor.showTabIndex": true,
	"workbench.editor.swipeToNavigate": true,
	"workbench.editor.useModal": "off",
	"workbench.editorAssociations": {
		"*.svg": "default"
	},
	"workbench.list.defaultFindMatchType": "contiguous",
	"workbench.preferredDarkColorTheme": "GitHub Dark Default",
	"workbench.preferredLightColorTheme": "GitHub Light Default",
	"workbench.settings.enableNaturalLanguageSearch": false,
	"workbench.settings.openDefaultSettings": true,
	"workbench.startupEditor": "none"
}
