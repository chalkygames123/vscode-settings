{
	"servers": {
		"astro-docs": {
			"type": "http",
			"url": "https://mcp.docs.astro.build/mcp"
		},
		"com.figma.mcp/mcp": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"gallery": "https://api.mcp.github.com"
		},
		"com.supabase/mcp": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp",
			"gallery": "https://api.mcp.github.com"
		},
		"heroui-pro": {
			"type": "http",
			"url": "https://mcp.heroui.pro/mcp",
			"headers": {
				"x-heroui-personal-token": "${input:HEROUI_PERSONAL_TOKEN}"
			}
		},
		"heroui-react": {
			"type": "stdio",
			"command": "pnx",
			"args": ["@heroui/react-mcp@latest"]
		},
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "pnx",
			"args": ["@sentry/mcp-server@latest"],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "pnx",
			"args": ["next-devtools-mcp@latest"],
			"gallery": "https://api.mcp.github.com"
		}
	},
	"inputs": [
		{
			"id": "HEROUI_PERSONAL_TOKEN",
			"type": "promptString",
			"description": "Your HeroUI Personal Token",
			"password": true
		},
		{
			"id": "SENTRY_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Sentry user authentication token",
			"password": true
		}
	]
}
