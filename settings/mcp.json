{
	"servers": {
		"awsdac-mcp-server": {
			"type": "stdio",
			"command": "/opt/homebrew/bin/awsdac-mcp-server"
		},
		"io.github.ChromeDevTools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "pnpx",
			"args": ["chrome-devtools-mcp@latest"],
			"gallery": "https://api.mcp.github.com"
		},
		"drawio": {
			"type": "http",
			"url": "https://mcp.draw.io/mcp"
		},
		"com.figma.mcp/mcp": {
			"type": "http",
			"url": "https://mcp.figma.com/mcp",
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.3"
		},
		"next-devtools": {
			"type": "stdio",
			"command": "pnpx",
			"args": ["next-devtools-mcp@latest"]
		},
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "pnpx",
			"args": ["@sentry/mcp-server@latest"],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com"
		},
		"com.supabase/mcp": {
			"type": "http",
			"url": "https://mcp.supabase.com/mcp",
			"gallery": "https://api.mcp.github.com"
		},
		"tanstack": {
			"type": "stdio",
			"command": "pnpx",
			"args": ["@tanstack/cli@latest", "mcp"]
		}
	},
	"inputs": [
		{
			"id": "SENTRY_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Sentry user authentication token",
			"password": true
		}
	]
}
